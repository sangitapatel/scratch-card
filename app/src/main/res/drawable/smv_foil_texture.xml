<?xml version="1.0" encoding="utf-8"?>
<!--
    smv_foil_texture.xml
    Used as:
      1. Local drawable foil for Card 2
      2. Placeholder while URL foil loads for Card 3
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base silver gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#B0BEC5"
                android:centerColor="#ECEFF1"
                android:endColor="#78909C"/>
        </shape>
    </item>

    <!-- Diagonal shimmer stripes overlay -->
    <item>
        <rotate
            android:fromDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <gradient
                    android:type="linear"
                    android:angle="0"
                    android:startColor="#00FFFFFF"
                    android:centerColor="#33FFFFFF"
                    android:endColor="#00FFFFFF"/>
            </shape>
        </rotate>
    </item>

</layer-list>
